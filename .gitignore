# General files for the project
pkg/*
*.pyc
bin/*
.project
/.bin
/_test/secrets/*.json

# OSX leaves these everywhere on SMB shares
._*

# OSX trash
.DS_Store

# Files generated by JetBrains IDEs, e.g. IntelliJ IDEA
.idea/
*.iml

# Vscode files
.vscode

# Emacs save files
*~
\#*\#
.\#*

# Vim-related files
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]
*.un~
Session.vim
.netrwhist

# Chart dependencies
**/charts/*.tgz
**/charts
Chart.lock

# Local docs (specs, plans) - never committed
/docs/

.history

*.tgz

scripts/example_htpasswd/users.htpasswd

*.key
*.crt

# Vendored helm dependencies for local file:// charts (ArgoCD renders from these)
!clusters/management-cluster/setup-istio/charts/
!clusters/management-cluster/setup-istio/charts/*.tgz
!clusters/management-cluster/setup-kiali/charts/
!clusters/management-cluster/setup-kiali/charts/*.tgz
!clusters/management-cluster/cert-manager/charts/
!clusters/management-cluster/cert-manager/charts/*.tgz
